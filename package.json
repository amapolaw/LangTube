{
  "name": "langtube",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @langtube/core build && pnpm --filter @langtube/cloud-adapters build && pnpm --filter @langtube/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "sync": "pnpm --filter @langtube/cli sync",
    "validate-pack": "pnpm --filter @langtube/cli validate ../../data/materials/ted-ja-social-engineering-001",
    "import-pack": "pnpm --filter @langtube/cli import",
    "db:push": "pnpm --filter @langtube/web db:push",
    "desktop:dev": "pnpm --filter @langtube/desktop dev",
    "desktop:build": "pnpm --filter @langtube/desktop build"
  },
  "engines": {
    "node": ">=20"
  }
}
