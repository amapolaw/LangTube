  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "A veces, creo que estoy maldito.",
      "zh": "有时候，我觉得自己被诅咒了。",
      "grammar": "creer que + 陈述式：认为……（表主观判断）；estar + 形容词（maldito）表示（暂时的）状态。"
    },
    {
      "id": "pattern-2",
      "pattern": "Por algo que pasó antes de que yo naciera.",
      "zh": "是因为在我出生之前发生的某件事。",
      "grammar": "antes de que + 虚拟式（naciera）：在……之前；不同主语时从句须用虚拟式。"
    },
    {
      "id": "pattern-3",
      "pattern": "Hace mucho tiempo, había una familia.",
      "zh": "很久以前，有一个家庭。",
      "grammar": "hace + 时间：……以前；había（haber 的过去未完成时）＝「有」，用于叙述背景。"
    },
    {
      "id": "pattern-4",
      "pattern": "No soy como el resto de mi familia.",
      "zh": "我和家里其他人不一样。",
      "grammar": "ser como：像……一样（表本质特征）；el resto de：……的其余部分／其他人。"
    },
    {
      "id": "pattern-5",
      "pattern": "Se supone que no deba amar la música.",
      "zh": "照理说我不该热爱音乐。",
      "grammar": "se supone que：据说／照理说；deber + 原形动词：应该（此处虚拟式 deba 缓和语气）。"
    },
    {
      "id": "pattern-6",
      "pattern": "Mamá Coco tiene problemas para recordar las cosas.",
      "zh": "可可奶奶记东西有困难。",
      "grammar": "tener problemas para + 原形动词：在做……方面有困难／麻烦。"
    },
    {
      "id": "pattern-7",
      "pattern": "Abuelita dirige la casa como Mamá Imelda lo hizo.",
      "zh": "奶奶像伊梅尔达曾祖母那样操持这个家。",
      "grammar": "como + 句子：像……那样（引导方式状语从句）；中性代词 lo 复指前面的动作。"
    },
    {
      "id": "pattern-8",
      "pattern": "Creo que somos la única familia en México que odia la música.",
      "zh": "我觉得我们是墨西哥唯一讨厌音乐的家庭。",
      "grammar": "la única … que + 陈述式：唯一……的（que 引导定语从句）。"
    },
    {
      "id": "pattern-9",
      "pattern": "Hizo que la gente se enamorara de él.",
      "zh": "他让人们爱上了他。",
      "grammar": "hacer que + 虚拟式（enamorara）：使／让……；enamorarse de：爱上……。"
    },
    {
      "id": "pattern-10",
      "pattern": "El mejor músico de todos los tiempos.",
      "zh": "有史以来最伟大的音乐家。",
      "grammar": "el mejor + 名词 + de …：……中最好的（形容词最高级）；de todos los tiempos＝有史以来。"
    },
    {
      "id": "pattern-11",
      "pattern": "Pero cuando tocaba música, la gente lo amaba.",
      "zh": "但每当他演奏音乐时，人们都爱戴他。",
      "grammar": "过去未完成时（tocaba, amaba）：表示过去反复、习惯性的动作或背景。"
    },
    {
      "id": "pattern-12",
      "pattern": "Podría haber hecho dulces.",
      "zh": "她本来可以去做糖果的。",
      "grammar": "条件式 podría + haber + 过去分词：本可以（做过）……，表示过去未实现的可能。"
    },
    {
      "id": "pattern-13",
      "pattern": "Muéstrame lo que tienes, muchacho.",
      "zh": "把你的本事亮出来吧，小子。",
      "grammar": "肯定命令式 + 宾格代词后置并连写（muéstra + me）；lo que＝所……的东西。"
    },
    {
      "id": "pattern-14",
      "pattern": "Necesito una guitarra por un rato.",
      "zh": "我需要用一会儿吉他。",
      "grammar": "necesitar + 名词：需要……；por un rato：一会儿、暂时（表持续的短暂时段）。"
    }
  ],
