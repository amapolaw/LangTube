  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "満 ｺｰﾋｰの段ﾎﾞｰﾙ 全部 処分したんだって",
      "zh": "（听说）满把咖啡的纸箱全都处理掉了。",
      "grammar": "〜んだって：引用、传闻「（听说）……」，等于「〜そうだ／〜と言っていた」。"
    },
    {
      "id": "pattern-2",
      "pattern": "処分するまでに 何年かかったと思ってるの？",
      "zh": "（你以为）处理完花了多少年啊？",
      "grammar": "〜までに：在……之前（完成期限）；〜と思ってる(の)：反问对方「你以为……吗」。"
    },
    {
      "id": "pattern-3",
      "pattern": "あの段ボールの量で 幾らぐらいになったんですかね？",
      "zh": "那么多纸箱，大概卖了多少钱呢？",
      "grammar": "〜ぐらい：大约、大概；〜になる：（数量）达到；〜んですかね：委婉的自问式询问。"
    },
    {
      "id": "pattern-4",
      "pattern": "そんなもんでしょ 新品じゃあるまいし",
      "zh": "差不多就那样吧，又不是新品。",
      "grammar": "〜じゃあるまいし：又不是……（表示「既然不是，就理应……」的语气）。"
    },
    {
      "id": "pattern-5",
      "pattern": "毎朝 入れてくれてたコーヒーも やめさせて",
      "zh": "（把他）每天早上为我泡的咖啡也让他停了。",
      "grammar": "〜てくれる：（别人）为我做……；〜させる：使役「让……做／停止」。"
    },
    {
      "id": "pattern-6",
      "pattern": "満に無理させ過ぎてないかと 心配で…",
      "zh": "担心是不是让满太勉强了……",
      "grammar": "〜させ過ぎる：使役＋过度「让……做得太过」；〜ないかと（心配）：担心会不会……。"
    },
    {
      "id": "pattern-7",
      "pattern": "お母さんも協力してくれなきゃ 困るよ",
      "zh": "妈妈你不配合的话，（我）会为难的。",
      "grammar": "〜てくれなきゃ（＝てくれなければ）困る：（你）不为我做……我就为难，表恳求。"
    },
    {
      "id": "pattern-8",
      "pattern": "目先の優しさは 満のためになんないから",
      "zh": "眼前的温柔对满没有好处。",
      "grammar": "〜のためにならない：对……没有好处、不利于……；なんない＝ならない的口语。"
    },
    {
      "id": "pattern-9",
      "pattern": "彼女 休んでるからって なれなれしくしないで",
      "zh": "别因为她请假了就套近乎。",
      "grammar": "〜からって（＝からといって）：不能因为……就……；〜ないで：请不要……。"
    },
    {
      "id": "pattern-10",
      "pattern": "もう少し規則正しい生活したら？",
      "zh": "（你）稍微过点规律的生活如何？",
      "grammar": "〜たら？：（省略どう）表示委婉建议「……怎么样？／……吧」。"
    },
    {
      "id": "pattern-11",
      "pattern": "そんなに嫌なら 別れればいいじゃん",
      "zh": "那么讨厌的话，分手不就得了。",
      "grammar": "〜ばいい：……就好了（建议、解决办法）；〜じゃん：口语「不就……嘛」。"
    },
    {
      "id": "pattern-12",
      "pattern": "単身赴任で こっちに来てるんだって",
      "zh": "（听说他）是单身赴任来这边的。",
      "grammar": "〜で：以……的方式／状态；〜て来る：（朝说话人方向）过来；んだって表传闻。"
    },
    {
      "id": "pattern-13",
      "pattern": "ただ食べに行っただけなのに",
      "zh": "明明只是去吃个饭而已……",
      "grammar": "〜に行く：去（做某事）；ただ〜だけ：只不过……；〜のに：明明……却（表不满）。"
    },
    {
      "id": "pattern-14",
      "pattern": "学校でハルミンと 絶対話すなって言うし",
      "zh": "（她）还说在学校绝对不许跟阳海说话。",
      "grammar": "〜な：（动词终止形＋な）表禁止「不许……」；〜って言う：引用别人的话。"
    }
  ],
