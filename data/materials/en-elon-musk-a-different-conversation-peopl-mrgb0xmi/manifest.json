  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "You must make me blush.",
      "zh": "你真让我脸红了。",
      "grammar": "make + 宾语 + 动词原形：使／让某人做某事（make me blush＝让我脸红）；此处 must 表推测「一定、真是」。"
    },
    {
      "id": "pattern-2",
      "pattern": "All of us have so much to learn from you.",
      "zh": "我们所有人都有很多要向你学习的。",
      "grammar": "so much to + 动词原形：有很多要（做）的；learn from sb：向某人学习。"
    },
    {
      "id": "pattern-3",
      "pattern": "Because you've done it so many times.",
      "zh": "因为你已经做过很多次了。",
      "grammar": "现在完成时 have/has + 过去分词：表示到现在为止的经历；so many times：这么多次。"
    },
    {
      "id": "pattern-4",
      "pattern": "Are we going to be talking for a while?",
      "zh": "我们要聊上一阵子吗？",
      "grammar": "be going to + be + 动词-ing：将来进行时，表示将来某段时间正在进行的动作；for a while：一会儿，一阵子。"
    },
    {
      "id": "pattern-5",
      "pattern": "Um, sure. Why not?",
      "zh": "嗯，当然。有何不可？",
      "grammar": "Why not?：口语中表示欣然同意「好啊、有什么不可以的」。"
    },
    {
      "id": "pattern-6",
      "pattern": "May I trouble you for a coffee?",
      "zh": "能麻烦你给我一杯咖啡吗？",
      "grammar": "May I …?：礼貌地请求许可；trouble sb for sth：麻烦某人要某物（较客气）。"
    },
    {
      "id": "pattern-7",
      "pattern": "Can we get another coffee?",
      "zh": "我们能再来一杯咖啡吗？",
      "grammar": "Can we …?：提出请求；another + 单数名词：再一个、另一个。"
    },
    {
      "id": "pattern-8",
      "pattern": "One a day kind of thing.",
      "zh": "差不多是一天一杯那种。",
      "grammar": "… kind of thing：口语「……那种、诸如此类」，用于笼统描述；one a day＝每天一（杯）。"
    },
    {
      "id": "pattern-9",
      "pattern": "You're a lot bigger than I would have thought.",
      "zh": "你比我原以为的要壮实得多。",
      "grammar": "a lot + 比较级：……得多；would have thought：（原本）会以为，表与事实相反的推测。"
    },
    {
      "id": "pattern-10",
      "pattern": "It can spike up if there's some major event in the world.",
      "zh": "如果世界上有什么大事，它会骤然上升。",
      "grammar": "can 表可能性；if 引导条件状语从句；there's（there is）＋名词：有……；spike up：骤升。"
    },
    {
      "id": "pattern-11",
      "pattern": "Do you think that'll change?",
      "zh": "你觉得那会改变吗？",
      "grammar": "Do you think (that) …?：你认为……吗；that'll＝that will，表将来。"
    },
    {
      "id": "pattern-12",
      "pattern": "As far as social media goes, X is number one.",
      "zh": "就社交媒体而言，X 是第一。",
      "grammar": "as far as … goes：就……而言，谈到……方面；number one：第一，最好的。"
    },
    {
      "id": "pattern-13",
      "pattern": "If you had to wager a guess for tomorrow...",
      "zh": "如果非要你对明天做个大胆的猜测……",
      "grammar": "if you had to …：假设「如果你不得不……」（虚拟语气）；wager a guess：（大胆地）猜一猜。"
    },
    {
      "id": "pattern-14",
      "pattern": "That's interesting.",
      "zh": "那很有意思。",
      "grammar": "That's + 形容词：对刚说的内容作评价「那真是……」，是英语口语中最常用的回应句型之一。"
    }
  ],
