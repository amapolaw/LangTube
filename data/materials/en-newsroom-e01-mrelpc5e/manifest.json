  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "What do you think taxes are?",
      "zh": "你以为税收是什么？",
      "grammar": "What do you think + 主语 + be？：把疑问句嵌入 think 后的间接疑问语序（主语在前、动词在后）。"
    },
    {
      "id": "pattern-2",
      "pattern": "That was the last great president.",
      "zh": "那是最后一位伟大的总统。",
      "grammar": "the last + 形容词 + 名词：最后一个／上一个……；last 在此表「最后的」。"
    },
    {
      "id": "pattern-3",
      "pattern": "American individualism can't build roads.",
      "zh": "美国的个人主义修不了路。",
      "grammar": "can't + 动词原形：不能、无法做某事，表能力或可能性的否定。"
    },
    {
      "id": "pattern-4",
      "pattern": "I am more than happy to pay for a fire department.",
      "zh": "我非常乐意为消防局出钱。",
      "grammar": "more than + 形容词：非常、极其……；be happy to do：乐意做……；pay for：为……付钱。"
    },
    {
      "id": "pattern-5",
      "pattern": "Can you say why America is the greatest country in the world?",
      "zh": "你能说说为什么美国是世界上最伟大的国家吗？",
      "grammar": "Can you say why …?：能否说明为什么；the greatest … in the world：世界上最……（形容词最高级）。"
    },
    {
      "id": "pattern-6",
      "pattern": "Do you consider yourself a Democrat, a Republican or Independent?",
      "zh": "你认为自己是民主党人、共和党人还是无党派人士？",
      "grammar": "consider oneself + 名词：认为／把自己看作……；A, B or C：三者选一的并列。"
    },
    {
      "id": "pattern-7",
      "pattern": "Are you willing to say whether you lean right or left?",
      "zh": "你愿意表明自己是偏右还是偏左吗？",
      "grammar": "be willing to do：愿意做……；whether … or …：是……还是……（引导宾语从句）。"
    },
    {
      "id": "pattern-8",
      "pattern": "How do you feel about that?",
      "zh": "你对此有什么感受？",
      "grammar": "How do you feel about …?：询问对某事的感受或看法，是常用的开放式提问句型。"
    },
    {
      "id": "pattern-9",
      "pattern": "Let's move on to the next question.",
      "zh": "我们进入下一个问题吧。",
      "grammar": "Let's + 动词原形：（提议）我们来……吧；move on to：转到、继续进行到……。"
    },
    {
      "id": "pattern-10",
      "pattern": "First step in solving any problem is recognizing there is one.",
      "zh": "解决任何问题的第一步，是承认问题的存在。",
      "grammar": "in + 动名词（solving）：在做……方面；is + 动名词（recognizing）作表语；there is one＝存在一个（问题）。"
    },
    {
      "id": "pattern-11",
      "pattern": "You're popular because you don't bother anyone.",
      "zh": "你受欢迎，是因为你不招惹任何人。",
      "grammar": "because 引导原因状语从句；don't + 动词原形＋anyone：否定句中用 anyone 表「任何人」。"
    },
    {
      "id": "pattern-12",
      "pattern": "I've voted for candidates run by both major parties.",
      "zh": "我投过两大政党推出的候选人的票。",
      "grammar": "现在完成时 I've voted：表经历；run by …：过去分词短语作后置定语「由……推出／管理的」。"
    },
    {
      "id": "pattern-13",
      "pattern": "That sounds like a good answer. I'll take it.",
      "zh": "这听起来是个不错的答案，我接受了。",
      "grammar": "sound like + 名词：听起来像……；I'll take it：我就要它了／我接受（口语常用）。"
    },
    {
      "id": "pattern-14",
      "pattern": "So let's keep it that way.",
      "zh": "那我们就保持这样吧。",
      "grammar": "keep + 宾语 + 状语（that way）：使……保持某种状态；that way＝那样，那种方式。"
    }
  ],
