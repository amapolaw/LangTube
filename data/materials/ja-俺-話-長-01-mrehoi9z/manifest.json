  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "出るわけないだろう",
      "zh": "怎么可能出去呢。",
      "grammar": "〜わけがない／わけない：表示「不可能……」，对可能性的强烈否定；だろう加强断定语气。"
    },
    {
      "id": "pattern-2",
      "pattern": "俺のせいにしないでよ",
      "zh": "别怪到我头上。",
      "grammar": "〜のせいにする：把（过错、责任）归咎于……；〜ないで(よ)：请不要……（口语请求／命令）。"
    },
    {
      "id": "pattern-3",
      "pattern": "しかし あそこまで 流行らないとは思わなかったな",
      "zh": "不过没想到会那么不受欢迎啊。",
      "grammar": "〜とは思わなかった：没想到竟会……，对出乎意料之事的感叹。"
    },
    {
      "id": "pattern-4",
      "pattern": "あの店 畳んで どれくらいになる？",
      "zh": "那家店关掉多久了？",
      "grammar": "〜になる：（时间／数量）到……、达到……；「店を畳む」＝歇业、关店。"
    },
    {
      "id": "pattern-5",
      "pattern": "この店を継ぐ気はないんですか？",
      "zh": "你没有继承这家店的打算吗？",
      "grammar": "〜気はない：没有……的打算／意愿；〜んですか：委婉询问缘由或事实。"
    },
    {
      "id": "pattern-6",
      "pattern": "ウチで出すコーヒーは 偽物だって",
      "zh": "（他说）我们店里端出的咖啡是假货。",
      "grammar": "〜だって：引用他人所说「（据说）……」，等于「〜と言っていた」。"
    },
    {
      "id": "pattern-7",
      "pattern": "もう諦めてるから",
      "zh": "（我）已经死心了。",
      "grammar": "〜ている：表示状态的持续（已处于放弃的状态）；から在句尾表原因或缓和语气。"
    },
    {
      "id": "pattern-8",
      "pattern": "ＡＴＭだったら ５０枚まで硬貨 入れられるから",
      "zh": "如果是ATM的话，硬币最多能存50枚。",
      "grammar": "〜だったら：假定「如果是……」；〜られる：可能形「能够……」。"
    },
    {
      "id": "pattern-9",
      "pattern": "自分で信金 行って来なさいよ",
      "zh": "你自己去趟信用社啦。",
      "grammar": "〜て来る：去（做某事）再回来；〜なさい：（长辈对晚辈）「去做……吧」的命令。"
    },
    {
      "id": "pattern-10",
      "pattern": "半年も持たなかったよね？",
      "zh": "连半年都没撑住吧？",
      "grammar": "〜も＋否定：连……都（不）……，强调程度之低；「持つ」＝维持、撑住。"
    },
    {
      "id": "pattern-11",
      "pattern": "やっぱり違うなって 思わされちゃう",
      "zh": "还是会不由得觉得（味道）就是不一样。",
      "grammar": "〜(さ)せられる／される：使役被动「不由得被……」；〜ちゃう＝〜てしまう（不禁、竟然）。"
    },
    {
      "id": "pattern-12",
      "pattern": "相談に乗って 何とか 解決策をひねり出したいな",
      "zh": "（我）想帮忙出主意，好歹想出个解决办法。",
      "grammar": "「相談に乗る」＝为人出主意；〜たい：想要……；「何とか」＝设法、好歹。"
    },
    {
      "id": "pattern-13",
      "pattern": "何で そんなに うれしそうに言うんですか？",
      "zh": "为什么你说得那么开心呀？",
      "grammar": "〜そう(だ)：看起来……（样态）；「うれしそうに」＝一副高兴的样子地。"
    },
    {
      "id": "pattern-14",
      "pattern": "作業着で行ったら 露骨に嫌な顔されましたからね",
      "zh": "穿着工作服去，（对方）露骨地摆出一副嫌弃的脸色。",
      "grammar": "〜たら：一……就……（发现／结果）；〜される：被动「被……」；から(ね)表原因。"
    }
  ],
