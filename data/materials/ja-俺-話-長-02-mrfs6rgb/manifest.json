  "patterns": [
    {
      "id": "pattern-1",
      "pattern": "もうちょっと 悩んだほうがいいんだよ",
      "zh": "（你）应该再多烦恼一下才对呀。",
      "grammar": "〜たほうがいい：表示建议「最好……」；んだ(よ)在句尾加强说明与劝告语气。"
    },
    {
      "id": "pattern-2",
      "pattern": "元気出してもらわなきゃと 思ってね",
      "zh": "（我）想着得让她打起精神来才行呢。",
      "grammar": "〜てもらう：请／让别人为自己做某事；〜なきゃ＝〜なければ（ならない）「必须……」的口语缩略。"
    },
    {
      "id": "pattern-3",
      "pattern": "こんなに食べられないよ",
      "zh": "（我）吃不了这么多啦。",
      "grammar": "〜られる：可能形「能够……」，此处否定「食べられない＝吃不下」；こんなに＝这么、如此。"
    },
    {
      "id": "pattern-4",
      "pattern": "そろそろ出ておかないと 通勤時間が心配なんで",
      "zh": "再不早点出门的话，通勤时间就令人担心了。",
      "grammar": "〜ておく：事先做好准备；〜ないと（＝ないといけない）「不……就不行」；〜なんで＝なので（表原因）。"
    },
    {
      "id": "pattern-5",
      "pattern": "｢いってらっしゃい｣ぐらい 言ってあげなさいよ",
      "zh": "至少说句「路上小心」给他嘛。",
      "grammar": "〜ぐらい：至少、起码（表最低限度）；〜てあげる：为他人做……；〜なさい：（长辈对晚辈）「去做……吧」。"
    },
    {
      "id": "pattern-6",
      "pattern": "じゃあ 食べてなかったら 言えるわけね？",
      "zh": "那么，要是没吃的话就能说得出来喽？",
      "grammar": "〜たら：假定「如果……」；〜わけ(ね)：表示据此推断出的结论「也就是说……喽」。"
    },
    {
      "id": "pattern-7",
      "pattern": "お母さんが起きる時間に 合わせて起きて来てるの？",
      "zh": "（他）是配合妈妈起床的时间起来的吗？",
      "grammar": "〜に合わせて：配合……、按照……；〜て来る：（动作朝说话人方向）过来、一直……过来。"
    },
    {
      "id": "pattern-8",
      "pattern": "コーヒーを入れるためだけに 朝の５時半まで起きてるの？",
      "zh": "就只为了泡杯咖啡而一直熬到早上五点半吗？",
      "grammar": "〜ために：为了……（目的）；だけに＝仅仅为了；〜ている：动作／状态的持续。"
    },
    {
      "id": "pattern-9",
      "pattern": "そのことについて お母さん 何とも思わないわけ？",
      "zh": "关于那件事，妈妈难道一点想法都没有吗？",
      "grammar": "〜について：关于……；何とも〜ない：一点也（不）……；〜わけ：表示反问、追究缘由。"
    },
    {
      "id": "pattern-10",
      "pattern": "早く食べないと遅刻するよ",
      "zh": "不快点吃的话会迟到哦。",
      "grammar": "〜ないと：（省略后半的いけない）「不……就……（不好的结果）」；表示条件性提醒。"
    },
    {
      "id": "pattern-11",
      "pattern": "そうだ 牛乳取って来ないと",
      "zh": "对了，得去把牛奶拿来才行。",
      "grammar": "〜て来る：去（做某事）再回来；〜ないと：（省略后半）「不……不行」，表自我提醒。"
    },
    {
      "id": "pattern-12",
      "pattern": "何歳だと思ってたんですか？",
      "zh": "（你）以为（我）多少岁啊？",
      "grammar": "〜と思う：认为……；〜ていた：过去持续的想法「一直以为」；んですか委婉询问。"
    },
    {
      "id": "pattern-13",
      "pattern": "僕 年上に見られたの初めてです",
      "zh": "我还是头一次被看成年长的。",
      "grammar": "〜に見られる：被看作／被认为（受身被动）；〜の(が)初めて：……是第一次。"
    },
    {
      "id": "pattern-14",
      "pattern": "学校 また通い始めたって",
      "zh": "（听说）她又开始去上学了。",
      "grammar": "〜始める：开始……（动词连用形＋始める）；〜って：引用他人所说「（听说）……」。"
    }
  ],
