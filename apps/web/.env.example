# Optional LLM API for in-app parsing
LLM_API_KEY=
LLM_PROVIDER=openai

# Google Drive OAuth
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:3000/api/cloud/gdrive/callback

# Baidu Pan OAuth
BAIDU_APP_KEY=
BAIDU_SECRET_KEY=
BAIDU_REDIRECT_URI=http://localhost:3000/api/cloud/baidu/callback

# Data directory (default: ../../data from apps/web)
LANGTUBE_DATA_DIR=

# GitHub sync
GITHUB_REPO=
GITHUB_TOKEN=
