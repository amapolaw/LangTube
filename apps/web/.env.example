# Cursor SDK（可选：在 Cursor IDE 终端运行时可留空，使用已登录会话）
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# 备选 LLM（无 Cursor 会话时使用）
LLM_API_KEY=
LLM_PROVIDER=openai
# 可选：本地 OpenAI 兼容代理（如 cursor-api-proxy :8765）
# LLM_BASE_URL=http://127.0.0.1:8765/v1

# yt-dlp（YouTube/B站/百度网盘 字幕与下载；若遇登录验证可指定浏览器 Cookie）
# YTDLP_PATH=/opt/homebrew/bin/yt-dlp
# YTDLP_COOKIES_FROM_BROWSER=chrome
# BILIBILI_COOKIES=SESSDATA=...; bili_jct=...

# Google Drive OAuth
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REDIRECT_URI=http://localhost:3000/api/cloud/gdrive/callback

# Baidu Pan OAuth
BAIDU_APP_KEY=
BAIDU_SECRET_KEY=
BAIDU_REDIRECT_URI=http://localhost:3000/api/cloud/baidu/callback

# 本机语言参考资料目录（等级词库 / 教材）
# 默认：~/Documents/Language （含 日本語、English、Español）
# LANGTUBE_LANGUAGE_DIR=/Users/junowang/Documents/Language

# Data directory (default: ../../data from apps/web)
LANGTUBE_DATA_DIR=

# GitHub 同步（同一公开仓库）
GITHUB_REPO=amapolaw/LangTube
GITHUB_TOKEN=
